# Copy to .env and fill in values
# Never commit .env to git

# Your Second Brain backend URL
API_BASE_URL=https://YOUR_RAILWAY_OR_NGROK_URL/api
EXPO_PUBLIC_API_BASE_URL=https://YOUR_RAILWAY_OR_NGROK_URL/api

# Public policy/support links shown in Settings and Play Console.
# If privacy/terms are omitted, the app derives them from EXPO_PUBLIC_API_BASE_URL by replacing /api with /privacy or /terms.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_OF_USE_URL=
EXPO_PUBLIC_SUPPORT_URL=mailto:support@nomirecall.app

# Firebase (from Firebase Console → Project Settings → Your apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Google Sign-In
# Use the Web client ID from Firebase Authentication / Google Cloud OAuth clients.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional iOS OAuth client ID; Android uses google-services.json + SHA fingerprints.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# RevenueCat (from RevenueCat Dashboard → Project → API Keys)
REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ANDROID_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=brain
EXPO_PUBLIC_REVENUECAT_BRAIN_PRODUCT_ID=brain_monthly
EXPO_PUBLIC_REVENUECAT_PRO_PRODUCT_ID=brain_pro_monthly
# Optional if Android Play product IDs differ from iOS/App Store product IDs.
EXPO_PUBLIC_REVENUECAT_ANDROID_BRAIN_PRODUCT_ID=brain_monthly
EXPO_PUBLIC_REVENUECAT_ANDROID_PRO_PRODUCT_ID=brain_pro_monthly

# Optional: Sentry for crash reporting
SENTRY_DSN=
