# Copy to .env and fill in values
# Never commit .env to git

# Your Second Brain backend URL
API_BASE_URL=https://YOUR_RAILWAY_OR_NGROK_URL/api

# Firebase (from Firebase Console → Project Settings → Your apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# RevenueCat (from RevenueCat Dashboard → Project → API Keys)
REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=brain
EXPO_PUBLIC_REVENUECAT_BRAIN_PRODUCT_ID=brain_monthly
EXPO_PUBLIC_REVENUECAT_PRO_PRODUCT_ID=brain_pro_monthly

# Optional: Sentry for crash reporting
SENTRY_DSN=
