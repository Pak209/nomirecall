{
  "name": "second-brain-app",
  "version": "1.0.0",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo start --dev-client --ios --localhost --clear --port 8083",
    "ios:prebuild": "expo prebuild --platform ios",
    "ios:run": "expo run:ios --port 8083",
    "start:staging": "EXPO_PUBLIC_API_BASE_URL=http://localhost:3001/api API_BASE_URL=http://localhost:3001/api expo start --localhost --clear --port 8091",
    "build:ios": "eas build --platform ios",
    "build:ios:simulator": "eas build --profile development --platform ios",
    "build:ios:device": "eas build --profile development-device --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:production": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --profile production --platform ios",
    "postinstall": "node scripts/patch-expo-ios-compat.js",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "test:backend": "cd backend && npm run test",
    "test:frontend:dashboard": "jest --runInBand src/screens/__tests__/NomiDashboardScreen.test.tsx --watchAll=false",
    "typecheck": "tsc --noEmit",
    "check:ci": "npm run typecheck && npm run test:backend && npm run test:frontend:dashboard",
    "check:quick": "npm run typecheck && npm run test:backend && npm run test:frontend:dashboard",
    "check:full": "npm run typecheck && npm run test:backend && npm test -- --watchAll=false"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@tanstack/react-query": "^4.41.0",
    "expo": "~51.0.0",
    "expo-apple-authentication": "~6.4.0",
    "expo-constants": "~16.0.0",
    "expo-dev-client": "~4.0.29",
    "expo-document-picker": "~12.0.0",
    "expo-file-system": "~17.0.0",
    "expo-font": "~12.0.0",
    "expo-haptics": "~13.0.0",
    "expo-linear-gradient": "~13.0.0",
    "expo-notifications": "~0.28.0",
    "expo-secure-store": "~13.0.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.1",
    "expo-web-browser": "~13.0.0",
    "react": "18.2.0",
    "react-native": "^0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-purchases": "^10.1.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "3.31.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.2.79",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eas-cli": "^18.11.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~7.1.2",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.4",
    "react-test-renderer": "^18.2.0",
    "typescript": "~5.3.3"
  }
}
