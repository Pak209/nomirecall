{
  "name": "second-brain-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "backfill:embeddings": "node scripts/backfill-embeddings.js",
    "backfill:memory-edges": "node scripts/backfill-memory-edges.js",
    "backfill:topic-pages": "node scripts/backfill-topic-pages.js",
    "debug:brain": "node scripts/nomi-debug.js brain",
    "debug:chunks": "node scripts/nomi-debug.js chunks",
    "debug:edges": "node scripts/nomi-debug.js edges",
    "debug:topics": "node scripts/nomi-debug.js topics",
    "debug:topic": "node scripts/nomi-debug.js topic",
    "eval:brain": "node scripts/brain-eval.js",
    "test": "node --test tests/*.js",
    "test:rules": "npx firebase emulators:exec --only firestore --project nomi-rules-test \"node --test tests/firestore-rules.test.js\"",
    "staging": "dotenv -e .env.staging -- node src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "dotenv-cli": "^8.0.0",
    "firebase-tools": "^15.22.4",
    "supertest": "^7.2.2"
  }
}
