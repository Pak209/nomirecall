PORT=3000
JWT_SECRET=dev-secret-change-me

# Firebase persistence (optional but recommended)
FIREBASE_PROJECT_ID=
# Option A: absolute path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option B: raw JSON string of service account (for cloud envs)
FIREBASE_SERVICE_ACCOUNT_JSON=

# X bookmarks OAuth MVP
X_CLIENT_ID=
# Optional for confidential X apps. Leave blank for public PKCE apps.
X_CLIENT_SECRET=
# Must exactly match the callback URL configured in the X developer portal.
X_REDIRECT_URI=http://localhost:3000/api/x/oauth/callback
# 32+ random chars recommended in production. Used to encrypt X refresh tokens.
X_TOKEN_ENCRYPTION_KEY=

# AI memory processing
NOMI_AI_PROVIDER=openai
OPENAI_API_KEY=
NOMI_AI_MODEL_SMALL=gpt-4o-mini
NOMI_AI_PROCESSING_VERSION=v1
# Optional cost controls
NOMI_AI_MIN_PROCESS_CHARS=40
NOMI_AI_MAX_INPUT_CHARS=6000
NOMI_AI_BATCH_LIMIT=20
NOMI_AI_DAILY_LIMIT_FREE=10
NOMI_AI_DAILY_LIMIT_EARLY_ACCESS=50
NOMI_AI_DAILY_LIMIT_ADMIN=150
NOMI_AI_DISABLE_LIMITS=false

# Scheduled jobs are off by default. Enable only in the production scheduler.
NOMI_DAILY_SYNC_ENABLED=false
NOMI_DAILY_BRIEF_SCHEDULER_ENABLED=false
